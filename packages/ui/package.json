{
  "name": "@repo/ui",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    "./styles.css": "./dist/index.css",
    "./*": "./dist/*.js"
  },
  "scripts": {
    "build": "npm run build:styles && npm run build:components",
    "build:styles": "tailwindcss -i ./src/styles.css -o ./dist/index.css --minify",
    "build:components": "tsc",
    "dev": "npm run dev:styles & npm run dev:components",
    "dev:styles": "tailwindcss -i ./src/styles.css -o ./dist/index.css --watch",
    "dev:components": "tsc --watch",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o storybook-static",
    "clean": "rm -rf dist storybook-static node_modules"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/tailwind-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@storybook/addon-essentials": "^8.6.17",
    "@storybook/addon-themes": "^8.6.17",
    "@storybook/addon-viewport": "^8.6.17",
    "@storybook/blocks": "^8.6.17",
    "@storybook/react": "^8.6.17",
    "@storybook/react-vite": "^8.6.17",
    "@tailwindcss/cli": "^4.2.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "daisyui": "^5.5.19",
    "eslint": "^9.39.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "storybook": "^8.6.17",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  }
}
